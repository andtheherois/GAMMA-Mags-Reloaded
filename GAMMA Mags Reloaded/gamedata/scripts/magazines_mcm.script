local function on_option_change()
    local a = get_config("highlight_clr_a") or 100
    local function resolve(key, fallback)
        local v = get_config(key)
        if v == "none" then return nil end          -- keep the base highlight
        return rax_persistent_highlight.change_alpha(colors[v] or fallback, a)
    end
    magazine_binder.ready_color = resolve("highlight_color", colors.orange)
    -- per-mark highlight colors share the base opacity
    -- nil means keeps the base highlight
    magazine_binder.mark_colors = {
        fmj  = resolve("mark_color_fmj",  colors.lime),
        ap   = resolve("mark_color_ap",   colors.aqua),
        hp   = resolve("mark_color_hp",   colors.orange),
        buck = resolve("mark_color_buck", colors.orange),
        slug = resolve("mark_color_slug", colors.white),
    }
    empty_table(magazines.cache_mag_time)
end

function on_game_start()
    RegisterScriptCallback("on_option_change",on_option_change)
    on_option_change()
end
