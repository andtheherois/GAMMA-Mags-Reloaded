local colors = {--alpha value will be reset to match slider
    orange = GetARGB(100, 255, 159, 82),
    pink = GetARGB(100, 255, 192, 203),
    blond = GetARGB(100, 240, 240, 190),
    white = GetARGB(100, 255, 255, 255),
    brown = GetARGB(100, 165, 42, 42),
    blue = GetARGB(100, 0, 0, 255),

    -- priler: colors extension
    lime = GetARGB(100, 141, 232, 52),
    khaki_green = GetARGB(100, 124, 159, 79),
    khaki_desert = GetARGB(100, 173, 146, 57),
    aqua = GetARGB(100, 49, 176, 231),
    purple = GetARGB(100, 164, 112, 235),
    teal = GetARGB(100, 7, 176, 176),
    teal_dark = GetARGB(100, 111, 151, 170),
}

-- shared palette for the per-mark color lists. "none" leaves the base highlight
-- color in place instead of overriding it for that group.
local COLOR_CONTENT = {
    {"none","none"},
    {"brown","ram_brown"},{"white","ram_white"},{"blond","ram_blond"},{"blue","ram_blue"},
    {"orange","ram_orange"},{"pink","ram_pink"},{"lime","ram_lime"},{"khaki_green","ram_khaki_green"},
    {"khaki_desert","ram_khaki_desert"},{"aqua","ram_aqua"},{"purple","ram_purple"},
    {"teal","ram_teal"},{"teal_dark","ram_teal_dark"},
}


function get_config(key)
    local grp = def_map[key]
    if ui_mcm and grp then return ui_mcm.get("magazines/"..grp.."/"..key) else return defaults[key] end
end

