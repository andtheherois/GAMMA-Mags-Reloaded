<?xml version="1.0" encoding="windows-1251"?>
<string_table>
    <!-- Sidebar subcategory name -->
    <string id="ui_mcm_menu_spinner">
        <text>Индикаторы</text>
    </string>

    <!-- Group title -->
    <string id="ui_mcm_magazines_spntitle">
        <text>Индикаторы</text>
    </string>

    <!-- Enable -->
    <string id="ui_mcm_magazines_spinner_spinner_enable">
        <text>Показывать индикатор загрузки</text>
    </string>
    <string id="ui_mcm_magazines_spinner_spinner_enable_desc">
        <text>Показывать анимированный индикатор над магазином, пока он заряжается или разряжается патрон за патроном.</text>
    </string>

    <!-- Style -->
    <string id="ui_mcm_magazines_spinner_spinner_style">
        <text>Стиль индикатора</text>
    </string>
    <string id="ui_mcm_magazines_spinner_spinner_style_desc">
        <text>Визуальный стиль анимации индикатора.</text>
    </string>

    <!-- Scale mode -->
    <string id="ui_mcm_magazines_spinner_spinner_scale">
        <text>Режим размера индикатора</text>
    </string>
    <string id="ui_mcm_magazines_spinner_spinner_scale_desc">
        <text>Как задаётся размер индикатора. Фиксированный использует размер ниже, Масштабируемый подгоняет его под значок магазина (с ограничением по размеру ниже).</text>
    </string>

    <!-- Size -->
    <string id="ui_mcm_magazines_spinner_spinner_size">
        <text>Размер индикатора (px)</text>
    </string>
    <string id="ui_mcm_magazines_spinner_spinner_size_desc">
        <text>Размер индикатора в пикселях (фиксированный режим) или максимальный размер (масштабируемый режим).</text>
    </string>

    <!-- Rotation speed -->
    <string id="ui_mcm_magazines_spinner_spinner_speed">
        <text>Скорость индикатора</text>
    </string>
    <string id="ui_mcm_magazines_spinner_spinner_speed_desc">
        <text>Регулирует скорость анимации индикатора. 1.0 - обычная, меньше - медленнее, больше - быстрее.</text>
    </string>

    <!-- Opacity -->
    <string id="ui_mcm_magazines_spinner_spinner_opacity">
        <text>Непрозрачность индикатора (%)</text>
    </string>
    <string id="ui_mcm_magazines_spinner_spinner_opacity_desc">
        <text>Прозрачность индикатора (10-100%).</text>
    </string>

    <!-- Dim enable -->
    <string id="ui_mcm_magazines_spinner_spinner_dim">
        <text>Затемнять значок магазина</text>
    </string>
    <string id="ui_mcm_magazines_spinner_spinner_dim_desc">
        <text>Немного затемнять значок магазина, пока активен индикатор.</text>
    </string>

    <!-- Dim amount -->
    <string id="ui_mcm_magazines_spinner_spinner_dim_amount">
        <text>Степень затемнения (%)</text>
    </string>
    <string id="ui_mcm_magazines_spinner_spinner_dim_amount_desc">
        <text>Насколько затемнять значок магазина во время зарядки (0 = без затемнения, больше = темнее).</text>
    </string>

    <!-- Box flash enable -->
    <string id="ui_mcm_magazines_spinner_box_flash_enable">
        <text>Мигание исходных патронов</text>
    </string>
    <string id="ui_mcm_magazines_spinner_box_flash_enable_desc">
        <text>Плавно затемнять и подсвечивать пачку (или стопку) патронов, из которой идёт зарядка, пока патроны перемещаются в магазин.</text>
    </string>

    <!-- Magazine flash enable -->
    <string id="ui_mcm_magazines_spinner_mag_flash_enable">
        <text>Мигание магазина</text>
    </string>
    <string id="ui_mcm_magazines_spinner_mag_flash_enable_desc">
        <text>Плавно затемнять и подсвечивать заряжаемый или разряжаемый магазин - та же пульсация, что и для исходных патронов. Использует общую силу и скорость, заданные ниже.</text>
    </string>

    <!-- Flash strength (shared by source ammo and magazine) -->
    <string id="ui_mcm_magazines_spinner_box_flash_strength">
        <text>Сила мигания (%)</text>
    </string>
    <string id="ui_mcm_magazines_spinner_box_flash_strength_desc">
        <text>Насколько значок затухает в тёмной фазе пульсации. Больше - прозрачнее, 100% полностью скрывает его. Общий параметр для мигания исходных патронов и магазина.</text>
    </string>

    <!-- Flash speed (shared by source ammo and magazine) -->
    <string id="ui_mcm_magazines_spinner_box_flash_speed">
        <text>Скорость мигания (%)</text>
    </string>
    <string id="ui_mcm_magazines_spinner_box_flash_speed_desc">
        <text>Скорость пульсации. 100% - примерно один цикл затухания в секунду. Общий параметр для мигания исходных патронов и магазина.</text>
    </string>

    <!-- Flash easing (shared by source ammo and magazine) -->
    <string id="ui_mcm_magazines_spinner_flash_easing">
        <text>Кривая мигания</text>
    </string>
    <string id="ui_mcm_magazines_spinner_flash_easing_desc">
        <text>Форма затухания. Линейная - постоянная скорость, Плавный вход держит яркость, затем резко гаснет, Плавный выход резко гаснет, затем затухает плавно, Плавный вход-выход плавный с обоих концов. Общий параметр для мигания исходных патронов и магазина.</text>
    </string>
    <string id="magazines_spinner_flash_easing_lst_linear">
        <text>Линейная</text>
    </string>
    <string id="magazines_spinner_flash_easing_lst_ease_in">
        <text>Плавный вход</text>
    </string>
    <string id="magazines_spinner_flash_easing_lst_ease_out">
        <text>Плавный выход</text>
    </string>
    <string id="magazines_spinner_flash_easing_lst_ease_in_out">
        <text>Плавный вход-выход (гладко)</text>
    </string>

    <!-- Fill gauge enable -->
    <string id="ui_mcm_magazines_spinner_gauge_enable">
        <text>Показывать шкалу заполнения</text>
    </string>
    <string id="ui_mcm_magazines_spinner_gauge_enable_desc">
        <text>Рисовать внешнее кольцо вокруг индикатора, которое заполняется по мере зарядки магазина, показывая степень заполнения.</text>
    </string>

    <!-- Fill gauge gap -->
    <string id="ui_mcm_magazines_spinner_gauge_gap">
        <text>Зазор шкалы (px)</text>
    </string>
    <string id="ui_mcm_magazines_spinner_gauge_gap_desc">
        <text>Насколько кольцо шкалы больше индикатора. Большие значения отодвигают кольцо дальше от индикатора.</text>
    </string>

    <!-- Fill gauge opacity -->
    <string id="ui_mcm_magazines_spinner_gauge_opacity">
        <text>Непрозрачность шкалы (%)</text>
    </string>
    <string id="ui_mcm_magazines_spinner_gauge_opacity_desc">
        <text>Прозрачность кольца шкалы заполнения (10-100%).</text>
    </string>

    <!-- Scale mode list values -->
    <string id="magazines_spinner_spinner_scale_lst_fixed">
        <text>Фиксированный размер</text>
    </string>
    <string id="magazines_spinner_spinner_scale_lst_scaled">
        <text>Масштаб по значку</text>
    </string>

    <!-- Style list values -->
    <string id="magazines_spinner_spinner_style_lst_default">
        <text>По умолчанию</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_arrows">
        <text>Стрелки</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_chasing_arrows">
        <text>Догоняющие стрелки</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_fading_line">
        <text>Затухающая линия</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_tarkov_like">
        <text>Тарков-лайк</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_growing_ring">
        <text>Растущее кольцо</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_half_circle">
        <text>Полукруг</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_half_circle_colored">
        <text>Полукруг (цветной)</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_half_circle_dimmed">
        <text>Полукруг (приглушённый)</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_half_circle_green">
        <text>Полукруг (зелёный)</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_line">
        <text>Линия</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_recycle">
        <text>Переработка</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_spinning_segments">
        <text>Вращающиеся сегменты</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_two_arrows">
        <text>Две стрелки</text>
    </string>
    <string id="magazines_spinner_spinner_style_lst_wheel">
        <text>Колесо</text>
    </string>




    <!-- Sidebar subcategory name -->
    <string id="ui_mcm_menu_field">
        <text>Полевая зарядка</text>
    </string>

    <!-- Group title -->
    <string id="ui_mcm_magazines_fldtitle">
        <text>Полевая зарядка</text>
    </string>

    <!-- Enable -->
    <string id="ui_mcm_magazines_field_field_load_enable">
        <text>Включить полевую зарядку</text>
    </string>
    <string id="ui_mcm_magazines_field_field_load_enable_desc">
        <text>Продолжать зарядку или разрядку магазина после закрытия инвентаря, с экранным индикатором и шкалой заполнения. При выключении возвращается классическое поведение: закрытие инвентаря отменяет зарядку.</text>
    </string>

    <!-- Show count text -->
    <string id="ui_mcm_magazines_field_field_hud_text">
        <text>Показывать счётчик патронов</text>
    </string>
    <string id="ui_mcm_magazines_field_field_hud_text_desc">
        <text>Показывать текущий счётчик патронов под шкалой, например "12 / 30", во время зарядки при закрытом инвентаре.</text>
    </string>

    <!-- Size -->
    <string id="ui_mcm_magazines_field_field_hud_size">
        <text>Размер полевого HUD (px)</text>
    </string>
    <string id="ui_mcm_magazines_field_field_hud_size_desc">
        <text>Размер экранного индикатора и шкалы, отображаемых во время зарядки при закрытом инвентаре.</text>
    </string>

    <!-- Opacity -->
    <string id="ui_mcm_magazines_field_field_hud_opacity">
        <text>Непрозрачность полевого HUD (%)</text>
    </string>
    <string id="ui_mcm_magazines_field_field_hud_opacity_desc">
        <text>Прозрачность экранного индикатора и шкалы (10-100%).</text>
    </string>

    <!-- X offset -->
    <string id="ui_mcm_magazines_field_field_hud_x_offset">
        <text>Смещение полевого HUD по X</text>
    </string>
    <string id="ui_mcm_magazines_field_field_hud_x_offset_desc">
        <text>Сдвигать полевой HUD влево или вправо от центра экрана.</text>
    </string>

    <!-- Y offset -->
    <string id="ui_mcm_magazines_field_field_hud_y_offset">
        <text>Смещение полевого HUD по Y</text>
    </string>
    <string id="ui_mcm_magazines_field_field_hud_y_offset_desc">
        <text>Сдвигать полевой HUD вверх или вниз от стандартного положения в нижней части по центру.</text>
    </string>

    <!-- Jump cancels loading -->
    <string id="ui_mcm_magazines_field_field_jump_cancel">
        <text>Прыжок отменяет зарядку</text>
    </string>
    <string id="ui_mcm_magazines_field_field_jump_cancel_desc">
        <text>Останавливать текущую полевую зарядку при прыжке. Прыжок сбивает аккуратную зарядку патрон за патроном, поэтому по умолчанию он её отменяет.</text>
    </string>
</string_table>
